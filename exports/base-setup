
# install python3 development environment
repro.require python-dev master ${REPROS_DEV} --default --code

# install geist, with the rdflib datastore extra (rdflib + owlrl)
if [[ "${GEIST_FROM_SOURCE}" == "true" ]] ; then
    # geist-p building its own image: install from the local working tree, with
    # all extras so geist-p's own demo (rdflib, clingo, duckdb datastores) runs.
    echo "Installing geist from local source tree (/repro) with all extras ..."
    sudo pip install '/repro[all]'
else
    # geist-p required by another repro: install the published package. The
    # rdflib extra is what trace-model (the current consumer) needs.
    echo "Installing geist-p[rdflib] from PyPI ..."
    sudo pip install 'geist-p[rdflib]'
fi
